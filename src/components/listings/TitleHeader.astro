---
import Image from "astro/components/Image.astro";

const { title, link, linkText, description, image } = Astro.props;
---

<div class="mb-10 rounded-[1.5rem] border border-cyan-300/15 bg-slate-950/70 p-6 shadow-2xl shadow-black/25 backdrop-blur sm:p-8">
  <div class="flex justify-between items-end gap-4">
    <div>
      {image && <Image class="h-15 w-15 mb-8" src={image} alt={title} />}
      <h1 class="font-bold text-4xl text-white">
        {title}
      </h1>
    </div>
    {
      link && (
        <a
          class="inline-flex items-center gap-1 font-medium text-cyan-100 hover:text-white"
          href={link}
        >
          {linkText}
          <span aria-hidden="true">↗</span>
        </a>
      )
    }
  </div>
  <p class="text-slate-300 mt-2.5">{description}</p>
</div>
