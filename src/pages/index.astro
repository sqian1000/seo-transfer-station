          <a href={href} class="rounded-[1.5rem] border border-white/10 bg-slate-950/65 p-6 no-underline shadow-xl shadow-black/20 transition hover:-translate-y-1 hover:border-cyan-300/50 hover:bg-cyan-300/10">
            <h3 class="text-xl font-black text-white">{title}</h3>
            <p class="mt-3 leading-7 text-slate-400">{text}</p>
            <span class="mt-5 inline-flex text-sm font-bold text-cyan-200">查看专题 →</span>
          </a>
        ))}
      </div>
    </section>

    <section id="production" class="mx-auto max-w-7xl px-5 py-14 md:px-8 lg:px-12">
      <div class="rounded-[2rem] border border-cyan-300/20 bg-gradient-to-br from-cyan-300/10 via-indigo-500/10 to-slate-950 p-8 md:p-10">
        <p class="text-sm font-bold uppercase tracking-[.25em] text-cyan-300">Production Checklist</p>
        <h2 class="mt-3 text-3xl font-black text-white md:text-5xl">从个人测试走向团队生产</h2>
