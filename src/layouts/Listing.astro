---
import BaseLayout from "./BaseLayout.astro";
import AppProse from "../components/app/Prose.astro";
const { frontmatter, slug } = Astro.props;
import themeConfig from "@util/themeConfig";
import AppShell from "@components/app/AppShell.astro";
import config from "@util/themeConfig";
import SidebarShell from "@components/app/SidebarShell.astro";
import TitleHeader from "@components/listings/TitleHeader.astro";

const siteTitle = themeConfig.general.title;
const title = frontmatter?.title || siteTitle;
const link = frontmatter?.link;
const description = frontmatter?.description;
const linkText = link?.replace(/^https?:\/\//, "");
const pageHeader = themeConfig.listings.pageHeader;
const sidebar = config.layout.sidebar;
const noindex = frontmatter?.noindex || slug === 'novel-tools';
---

<BaseLayout title={title} description={description} slug={slug} noindex={noindex}>
  {
    sidebar ? (
      <SidebarShell showSidebar={false}>
        <div class="mx-auto w-full max-w-4xl px-5 py-16 sm:px-6 lg:px-8">
          {pageHeader == "title" && (
            <TitleHeader
              title={title}
              description={description}
              link={link ? `/go/${slug}/` : undefined}
              linkText={link ? "查看详情" : linkText}
              image={frontmatter.image}
            />
          )}
          <section class="rounded-[1.5rem] border border-cyan-300/15 bg-slate-950/70 p-6 text-slate-200 shadow-2xl shadow-black/25 backdrop-blur sm:p-8">
            <AppProse>
              <slot />
            </AppProse>
          </section>
        </div>
      </SidebarShell>
    ) : (
      <AppShell>
        <div class="mx-auto w-full max-w-4xl px-5 py-16 sm:px-6 lg:px-8">
          {pageHeader == "title" && (
            <div class="mb-10 rounded-[1.5rem] border border-cyan-300/15 bg-slate-950/70 p-6 shadow-2xl shadow-black/25 backdrop-blur sm:p-8">
              <div class="flex justify-between items-center">
                <h1 class="font-bold text-4xl text-white">
                  {title}
                </h1>
                {link && (
                  <a
                    class="inline-flex items-center gap-1 font-medium text-cyan-100 hover:text-white"
                    href={`/go/${slug}/`}
                  >
                    查看详情
                    <span aria-hidden="true">↗</span>
                  </a>
                )}
              </div>
              <p class="text-slate-300 mt-2.5">{description}</p>
            </div>
          )}
          <section class="rounded-[1.5rem] border border-cyan-300/15 bg-slate-950/70 p-6 text-slate-200 shadow-2xl shadow-black/25 backdrop-blur sm:p-8">
            <AppProse>
              <slot />
            </AppProse>
          </section>
        </div>
      </AppShell>
    )
  }
</BaseLayout>
