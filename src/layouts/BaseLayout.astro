---
import "@fontsource-variable/gabarito";
import themeConfig from "@util/themeConfig";
import "../styles/global.css";
import Posthog from "@components/analytics/Posthog.astro";
import { ClientRouter } from "astro:transitions";
import { getOGImage } from "@util/getOGImage";

const { title, slug, description, noindex = false } = Astro.props;
const siteTitle = themeConfig.general.title;
const siteUrl = themeConfig.general.seo.url.replace(/\/$/, "");
const path = slug ? `/${String(slug).replace(/^\//, "")}` : "/";
const canonical = `${siteUrl}${path === "/" ? "" : path}`;

const calculatedTitle = title ? `${title}` : siteTitle;
const calculatedDescription = description || themeConfig.general.seo.description;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <link rel="canonical" href={canonical} />
    <meta name="generator" content={Astro.generator} />
    {noindex && <meta name="robots" content="noindex,nofollow" />}

    <title>{calculatedTitle}</title>
    <meta name="description" content={calculatedDescription} />

    <!-- Facebook Meta Tags -->
    <meta property="og:url" content={canonical} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={calculatedTitle} />
    <meta property="og:description" content={calculatedDescription} />
    <meta property="og:image" content={getOGImage(slug)} />

    <!-- Twitter Meta Tags -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta property="twitter:domain" content={new URL(themeConfig.general.seo.url).hostname} />
    <meta property="twitter:url" content={canonical} />
    <meta name="twitter:title" content={calculatedTitle} />
    <meta name="twitter:description" content={calculatedDescription} />
    <meta name="twitter:image" content={getOGImage(slug)} />
    <ClientRouter />
  </head>
  <body>
    <slot />
    <Posthog />
  </body>
</html>
